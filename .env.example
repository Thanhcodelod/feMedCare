# URL của Backend API (NestJS). Đổi sang domain thật khi deploy.
# Lưu ý: biến NEXT_PUBLIC_* được nhúng lúc BUILD, đổi giá trị phải build lại.
NEXT_PUBLIC_API_URL=http://localhost:8888

# Socket.IO namespace /teleconsultation chạy cùng tiến trình NestJS,
# nên thường giữ trùng với NEXT_PUBLIC_API_URL.
NEXT_PUBLIC_WS_URL=http://localhost:8888

# (Tuỳ chọn) Thông tin deploy tĩnh lên surge.sh — không bắt buộc.
SURGE_EMAIL=
SURGE_PASSWORD=
